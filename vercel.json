{

  "framework": null,

  "builds": [

    {

      "src": "PikiOra7420/wsgi.py",

      "use": "@vercel/python",

      "config": { "maxLambdaSize":  "15mb", "runtime":  "python3.9" }

    }

  ],

  "routes": [

    {

      "src": "/(.*)",

      "dest": "PikiOra7420/wsgi.py",

      "headers": {

        "Access-Control-Allow-Origin": "*",

        "Access-Control-Allow-Methods": "GET, POST, OPTIONS, DELETE, PUT"

      }

    },

    {

      "src": "/(.*)",

      "dest": "PikiOra7420/wsgi.py"

    }

  ]

}